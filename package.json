    "@tarojs/plugin-platform-h5": "4.1.9",
    "@tarojs/plugin-platform-harmony-hybrid": "4.1.9",
    "@tarojs/plugin-platform-jd": "4.1.9",
    "@tarojs/plugin-platform-qq": "4.1.9",
